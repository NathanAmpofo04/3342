@{
    ViewData["Title"] = "Upload Gallery Photos";
}

<div class="page-wrapper" style="max-width: 600px; margin: 50px auto;">
    <div class="hero">
        <h1>Gallery Upload</h1>
        <p class="muted">Select photos to add to your public profile gallery.</p>
    </div>

    <div class="section form-panel">
        @* --- ADD THIS ERROR BOX HERE --- *@
        @if (TempData["ErrorMessage"] != null)
        {
            <div style="margin-bottom:20px; padding: 15px; background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; border-radius: 5px; font-weight: bold;">
                Upload Failed: @TempData["ErrorMessage"]
            </div>
        }
        @* -------------------------------- *@

        <form asp-controller="Profile" asp-action="ProcessUpload" method="post" enctype="multipart/form-data">
            <input type="hidden" name="userId" value="@ViewBag.UserId" />

            <div class="form-group">
                <label>Select Image:</label>
                <input type="file" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,.gif" required />
            </div>

            <div class="form-group" style="margin-top:15px;">
                <label>Photo Caption:</label>
                <input type="text" name="imageTitle" class="form-control" placeholder="e.g. At the beach..." />
            </div>

            <div class="button-row" style="margin-top: 20px; display: flex; gap: 10px;">
                <button type="submit" class="btn btn-primary">Upload to Gallery</button>
                <a asp-controller="Login" asp-action="Dashboard" class="btn btn-secondary">Back to Dashboard</a>
            </div>
        </form>

        @if (TempData["Message"] != null)
        {
            <div style="margin-top:20px; color: green; font-weight: bold; text-align: center;">
                @TempData["Message"]
            </div>
        }
    </div>
</div>