@model List<TheLinkUp.Models.Event>

<div class="container">
    <h2 class="text-center mb-4">Discover Events</h2>

    <div class="row">
        @foreach (var evt in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow">
                    <img src="@evt.ImageURL" class="card-img-top" style="height: 220px; object-fit: cover;" />

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@evt.EventName</h5>

                        <p class="card-text">
                            <strong>Date:</strong> @evt.EventDate <br />
                            <strong>Venue:</strong> @evt.VenueName <br />
                            <strong>Location:</strong> @evt.City, @evt.State
                        </p>

                        <a asp-controller="Events"
                           asp-action="ViewEventDetails"
                           asp-route-id="@evt.EventID"
                           class="btn btn-primary mt-auto w-100">
                            See Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>