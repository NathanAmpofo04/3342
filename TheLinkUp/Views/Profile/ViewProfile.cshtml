@model TheLinkUp.Models.Profile

<div class="container mt-4">
    <div class="section-card">
        <div class="row">
            <div class="col-md-4">
                <img src="@Model.PhotoURL" class="img-fluid rounded" />
            </div>

            <div class="col-md-8 profile-info">
                <h2>@Model.FullName</h2>
                <p><strong>Age:</strong> @Model.Age</p>
                <p><strong>Occupation:</strong> @Model.Occupation</p>

                <p>
                    <strong>Location:</strong>
                    @if (!string.IsNullOrEmpty(Model.City) && !string.IsNullOrEmpty(Model.State))
                    {
                        @Model.City @(", ") @Model.State
                    }
                    else if (!string.IsNullOrEmpty(Model.City))
                    {
                        @Model.City
                    }
                    else if (!string.IsNullOrEmpty(Model.State))
                    {
                        @Model.State
                    }
                </p>

                <p><strong>Goals:</strong> @Model.Goals</p>
                <p><strong>Commitment Type:</strong> @Model.CommitmentType</p>
                <p><strong>Description:</strong> @Model.Description</p>
                <p><strong>Favorite Movie:</strong> @Model.FavoriteMovie</p>
                <p><strong>Favorite Restaurant:</strong> @Model.FavoriteRestaurant</p>
                <p><strong>Favorite Book:</strong> @Model.FavoriteBook</p>
                <p><strong>Favorite Poem:</strong> @Model.FavoritePoem</p>
                <p><strong>Favorite Quote:</strong> @Model.FavoriteQuote</p>
            </div>
        </div>
    </div>
</div>